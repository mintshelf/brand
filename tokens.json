      "onSecondary": { "$value": "#ffffff" },
      "secondaryContainer": { "$value": "#d4e8d1" },
      "onSecondaryContainer": { "$value": "#0f1f11" },
      "tertiary": { "$value": "#39656d" },
      "onTertiary": { "$value": "#ffffff" },
      "tertiaryContainer": { "$value": "#bdeaf3" },
      "onTertiaryContainer": { "$value": "#001f24" },
      "surface": { "$value": "#f9faf4" },
      "onSurface": { "$value": "#1a1c19" },
      "surfaceVariant": { "$value": "#dde5da" },
      "onSurfaceVariant": { "$value": "#414941" },
      "surfaceContainerLow": { "$value": "#f3f4ee" },
      "surfaceContainer": { "$value": "#edeee9" },
      "surfaceContainerHigh": { "$value": "#e7e9e3" },
      "outline": { "$value": "#727970" },
      "outlineVariant": { "$value": "#c1c9be" }
    },
    "dark": {
      "$type": "color",
      "primary": { "$value": "#4ae176" },
      "onPrimary": { "$value": "#003915" },
      "primaryContainer": { "$value": "#005321" },
      "onPrimaryContainer": { "$value": "#6bff8f" },
      "secondary": { "$value": "#b8ccb6" },
      "onSecondary": { "$value": "#233425" },
      "secondaryContainer": { "$value": "#394b3a" },
      "onSecondaryContainer": { "$value": "#d4e8d1" },
      "tertiary": { "$value": "#a1ced7" },
      "onTertiary": { "$value": "#00363d" },
      "tertiaryContainer": { "$value": "#1f4d55" },
      "onTertiaryContainer": { "$value": "#bdeaf3" },
      "surface": { "$value": "#111411" },
      "onSurface": { "$value": "#e2e3dd" },
      "surfaceVariant": { "$value": "#414941" },
      "onSurfaceVariant": { "$value": "#c1c9be" },
      "surfaceContainerLow": { "$value": "#1a1c19" },
      "surfaceContainer": { "$value": "#1e201d" },
      "surfaceContainerHigh": { "$value": "#282b27" },
      "outline": { "$value": "#8b9389" },
      "outlineVariant": { "$value": "#414941" }
    }
  },
  "font": {
    "sans": {
      "$type": "fontFamily",
      "$value": ["Public Sans", "system-ui", "sans-serif"]
    }
  },
  "radius": {
    "$type": "dimension",
    "extraSmall": { "$value": { "value": 4, "unit": "px" } },
    "small": { "$value": { "value": 8, "unit": "px" } },
    "medium": { "$value": { "value": 12, "unit": "px" } },
    "large": { "$value": { "value": 16, "unit": "px" } },
    "extraLarge": { "$value": { "value": 28, "unit": "px" } },
    "full": { "$value": { "value": 9999, "unit": "px" } }
  }
}
