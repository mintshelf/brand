{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "brand": {
      "mint": {
        "$type": "color",
        "$value": "#22c55e",
        "$description": "Mint Shelf seed and recognition color"
      }
    },
    "light": {
      "$type": "color",
      "primary": { "$value": "#006e2f" },
      "onPrimary": { "$value": "#ffffff" },
      "primaryContainer": { "$value": "#6bff8f" },
