#!/usr/bin/env bash
#MISE description="Validate the approved public brand surface"
set -euo pipefail

node scripts/validate-tokens.mjs
node scripts/validate-assets.mjs
test -f LICENSE.md
test -f GUIDELINES.md
test -f PROVENANCE.md

if grep -RIE \
  '(BEGIN (RSA|OPENSSH|EC) PRIVATE KEY|ghp_[A-Za-z0-9]{20,}|sk_live_[A-Za-z0-9]+)' \
  . --exclude-dir=.git; then
  echo 'Possible secret found.'
  exit 1
fi

if git config --global --get hook.hk-pre-push.command >/dev/null; then
  ! git config --local --get hook.hk-pre-push.command >/dev/null
else
  git config --local --get hook.hk-pre-push.command >/dev/null
fi
